{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"version": "24.11.1",
	"textdomain": "unitone",
	"name": "unitone/abstract-background",
	"title": "Abstract background",
	"description": "Displays a frame using an abstract background image.",
	"attributes": {
		"src": {
			"type": "string",
			"default": "mountain-1"
		},
		"templateLock": {
			"type": [ "string", "boolean" ],
			"enum": [ "all", "insert", "contentOnly", false ]
		}
	},
	"selectors": {
		"root": ".unitone-abstract-background"
	},
	"allowedBlocks": [
		"core/image",
		"core/video",
		"unitone/decorator",
		"unitone/frame"
	],
	"supports": {
		"className": false,
		"anchor": true,
		"customCSS": false,
		"align": [ "full", "wide" ],
		"contentRole": true,
		"unitone": {
			"padding": true,
			"backdropFilter": {
				"progressive": false
			}
		}
	},
	"category": "unitone/component",
	"editorScript": "file:./index.js",
	"style": "file:./style-index.css"
}
