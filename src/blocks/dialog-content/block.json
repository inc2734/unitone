{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"version": "27.1.0",
	"textdomain": "unitone",
	"name": "unitone/dialog-content",
	"title": "Dialog content",
	"description": "This block places the dialog content.",
	"attributes": {
		"templateLock": {
			"type": [ "string", "boolean" ],
			"enum": [ "all", "insert", "contentOnly", false ]
		}
	},
	"selectors": {
		"root": "[data-unitone-layout~=dialog-content]"
	},
	"parent": [ "unitone/dialog" ],
	"usesContext": [ "unitone/dialog/variation" ],
	"supports": {
		"inserter": false,
		"className": false,
		"anchor": true,
		"customCSS": false,
		"contentRole": true,
		"allowedBlocks": true,
		"lock": false,
		"unitone": {
			"containerType": true
		}
	},
	"category": "unitone/layout",
	"editorScript": "file:./index.js"
}
