{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"version": "26.0.0",
	"textdomain": "unitone",
	"name": "unitone/dialog-content",
	"title": "Dialog content",
	"description": "This block places the dialog content.",
	"attributes": {
		"closedBy": {
			"type": "string",
			"default": "any",
			"enum": [ "any", "closerequest", "none" ]
		},
		"templateLock": {
			"type": [ "string", "boolean" ],
			"enum": [ "all", "insert", "contentOnly", false ]
		}
	},
	"selectors": {
		"root": "[data-unitone-layout~=dialog-content]"
	},
	"parent": [ "unitone/dialog" ],
	"supports": {
		"inserter": false,
		"className": false,
		"anchor": true,
		"customCSS": false,
		"color": {
			"background": true,
			"gradients": true,
			"link": true,
			"text": true
		},
		"typography": {
			"fontSize": true,
			"__experimentalFontFamily": true,
			"__experimentalTextDecoration": true,
			"__experimentalFontStyle": true,
			"__experimentalFontWeight": true,
			"__experimentalLetterSpacing": true,
			"__experimentalTextTransform": true,
			"__experimentalDefaultControls": {
				"fontSize": true
			}
		},
		"allowedBlocks": true,
		"contentRole": true,
		"unitone": {
			"maxHeight": true,
			"maxWidth": true
		}
	},
	"category": "unitone/layout",
	"editorScript": "file:./index.js"
}
