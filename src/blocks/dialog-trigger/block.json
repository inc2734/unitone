{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"version": "26.0.0",
	"textdomain": "unitone",
	"name": "unitone/dialog-trigger",
	"title": "Dialog trigger",
	"description": "This block is used to place the block that triggers the dialog. The trigger is fired by clicking a button block or decorator block (role: button) in this block.",
	"attributes": {
		"templateLock": {
			"type": [ "string", "boolean" ],
			"enum": [ "all", "insert", "contentOnly", false ]
		}
	},
	"selectors": {
		"root": "[data-unitone-layout~=dialog-trigger]"
	},
	"parent": [ "unitone/dialog" ],
	"allowedBlocks": [ "core/buttons", "unitone/decorator" ],
	"supports": {
		"inserter": false,
		"className": false,
		"customCSS": false,
		"lock": false
	},
	"category": "unitone/layout",
	"editorScript": "file:./index.js"
}
