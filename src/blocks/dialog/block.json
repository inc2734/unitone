{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"version": "26.0.0",
	"textdomain": "unitone",
	"name": "unitone/dialog",
	"title": "Dialog",
	"description": "Displays modal content using the dialog element.",
	"attributes": {
		"templateLock": {
			"type": [ "string", "boolean" ],
			"enum": [ "all", "insert", "contentOnly", false ]
		}
	},
	"selectors": {
		"root": "[data-unitone-layout~=dialog]"
	},
	"allowedBlocks": [ "unitone/dialog-trigger", "unitone/dialog-content" ],
	"supports": {
		"className": false,
		"anchor": true,
		"customCSS": false,
		"unitone": {
			"gap": true
		}
	},
	"example": {
		"innerBlocks": [
			{
				"name": "unitone/dialog-trigger",
				"innerBlocks": [
					{
						"name": "core/buttons",
						"innerBlocks": [
							{
								"name": "core/button"
							}
						]
					}
				]
			},
			{
				"name": "unitone/dialog-content",
				"innerBlocks": [
					{
						"name": "core/paragraph",
						"attributes": {
							"content": "Dialog content."
						}
					}
				]
			}
		]
	},
	"category": "unitone/layout",
	"editorScript": "file:./index.js",
	"style": "file:./style-index.css",
	"editorStyle": "file:./index.css"
}
