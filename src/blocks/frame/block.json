{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"version": "26.0.0",
	"textdomain": "unitone",
	"name": "unitone/frame",
	"title": "Frame",
	"description": "This block is used to fit the image into a fixed angle of view.",
	"attributes": {
		"ratio": {
			"type": "string",
			"default": "16/9"
		},
		"switchRatio": {
			"type": "boolean",
			"default": false
		},
		"templateLock": {
			"type": [ "string", "boolean" ],
			"enum": [ "all", "insert", "contentOnly", false ]
		}
	},
	"selectors": {
		"root": "[data-unitone-layout~=frame]"
	},
	"allowedBlocks": [ "core/image", "core/video", "core/post-featured-image" ],
	"supports": {
		"className": false,
		"anchor": true,
		"customCSS": false,
		"shadow": {
			"__experimentalDefaultControls": {
				"shadow": true
			}
		},
		"__experimentalBorder": {
			"color": true,
			"radius": true,
			"style": true,
			"width": true,
			"__experimentalDefaultControls": {
				"color": true,
				"radius": true,
				"style": true,
				"width": true
			}
		},
		"contentRole": true,
		"unitone": {
			"queryContext": true,
			"opacity": true,
			"parallax": true,
			"scrollAnimation": true,
			"loopAnimation": true,
			"hoverAnimation": true
		}
	},
	"category": "unitone/layout",
	"editorScript": "file:./index.js",
	"style": "file:./style-index.css",
	"editorStyle": "file:./index.css"
}
